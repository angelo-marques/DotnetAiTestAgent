{
  /*
   * Configuração do Serilog via appsettings.json
   * 
   * Em aplicações web o Serilog lê esta seção via .ReadFrom.Configuration()
   * no builder.Host.UseSerilog() do Program.cs.
   * 
   * Vantagem: mudar nível de log, destinos e templates sem recompilar.
   */
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        /*
         * Reduz verbosidade dos frameworks internos.
         * Sem isso, o ASP.NET Core imprime centenas de linhas de Debug
         * de roteamento, middleware e DI a cada request.
         */
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext", // propriedades injetadas via using (LogContext.PushProperty(...))
      "WithEnvironmentName", // Development / Production / Staging
      "WithThreadId" // útil para rastrear execuções paralelas dos agentes
    ],
    "WriteTo": [
      {
        /*
         * Console — saída colorida no terminal.
         * outputTemplate controla o formato de cada linha.
         * 
         * Placeholders disponíveis:
         *   {Timestamp}      → data/hora
         *   {Level}          → nível (Information, Warning, Error...)
         *   {SourceContext}  → nome do ILogger<T> que emitiu o log
         *   {Message}        → mensagem formatada
         *   {NewLine}        → quebra de linha
         *   {Exception}      → stack trace (só aparece quando há exceção)
         *   {Properties}     → todas as propriedades extras (ThreadId, etc.)
         *   {EnvironmentName}→ vem do enricher WithEnvironmentName
         */
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        /*
         * File — arquivo rotacionado diariamente.
         * rollingInterval: "Day" → cria um arquivo por dia
         * retainedFileCountLimit: mantém os últimos 30 dias
         */
        "Name": "File",
        "Args": {
          "path": "logs/ai-test-agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:dd/MM/yyyy HH:mm:ss} {Level:u3}] [{EnvironmentName}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "AllowedHosts": "*"
}