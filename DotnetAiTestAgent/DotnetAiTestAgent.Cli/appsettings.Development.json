{
  /*
   * Sobrescreve o appsettings.json apenas em ambiente Development.
   * Em produção este arquivo não existe / não é carregado.
   * 
   * Diferenças em dev:
   * - Nível padrão: Debug (em vez de Information)
   * - Microsoft.AspNetCore: Information (em vez de Warning) — ver roteamento
   * - Sem sink de arquivo (não poluir logs locais)
   */
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  }
}